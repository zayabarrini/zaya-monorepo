{
  "name": "zaya-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:spacedesign": "npm run dev --workspace=apps/spacedesign",
    "dev:signflow": "npm run dev --workspace=apps/signflow", 
    "dev:transliteration": "cd apps/transliteration && python api/index.py",
    "build:spacedesign": "npm run build --workspace=apps/spacedesign",
    "build:signflow": "npm run build --workspace=apps/signflow",
    "build:transliteration": "echo 'Python build complete'",
    "dev": "npm run dev:spacedesign"
  },
  "workspaces": ["apps/*", "packages/*"],
  "devDependencies": {
    "prettier": "^3.0.0",
    "prettier-plugin-svelte": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": "18.x"
  }
}
