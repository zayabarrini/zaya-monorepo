		"axe-core": "^4.8.0",
		"bootstrap": "^5.3.3",
		"eslint": "^8.28.0",
		"eslint-config-prettier": "^8.5.0",
		"eslint-plugin-svelte": "^2.30.0",
		"jest": "^30.2.0",
		"jsdom": "^23.2.0",
		"katex": "^0.16.21",
